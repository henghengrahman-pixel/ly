<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login</title>
  <link rel="icon" type="image/png" href="/favicon.png">
  <style>
    *{box-sizing:border-box} body{margin:0;min-height:100vh;background:radial-gradient(circle at top,#1f2937,#020617 60%);font-family:Arial,sans-serif;color:#fff;display:flex;align-items:center;justify-content:center;padding:20px}.card{width:100%;max-width:420px;background:rgba(15,23,42,.96);border:1px solid rgba(255,255,255,.12);border-radius:22px;padding:28px;box-shadow:0 20px 60px rgba(0,0,0,.45)}h1{margin:0 0 8px;font-size:28px}.muted{color:#94a3b8;margin:0 0 22px}label{display:block;margin:14px 0 7px;font-weight:700}input{width:100%;padding:14px;border-radius:13px;border:1px solid #334155;background:#020617;color:#fff;font-size:15px}button{width:100%;margin-top:22px;border:0;border-radius:14px;padding:14px;background:#f97316;color:#fff;font-weight:800;font-size:16px;cursor:pointer}.err{background:#7f1d1d;color:#fecaca;padding:12px;border-radius:12px;margin-bottom:14px}.back{display:block;text-align:center;color:#cbd5e1;text-decoration:none;margin-top:16px}
  </style>
</head>
<body>
  <form class="card" method="POST" action="/admin/login">
    <h1>Admin Panel</h1>
    <p class="muted">Login untuk ubah nomor, link, foto, dan background.</p>
    <% if (error) { %><div class="err"><%= error %></div><% } %>
    <label>User ID</label>
    <input name="userId" autocomplete="username" required>
    <label>Password</label>
    <input name="password" type="password" autocomplete="current-password" required>
    <button type="submit">LOGIN</button>
    <a class="back" href="/">Kembali ke halaman utama</a>
  </form>
</body>
</html>
