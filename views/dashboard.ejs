<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard Admin</title>
<link rel="icon" href="/favicon.png">

<style>
*{box-sizing:border-box}
body{
  margin:0;
  background:#020617;
  color:#e5e7eb;
  font-family:Arial,sans-serif;
  padding:22px;
}

.top{
  max-width:1100px;
  margin:auto;
  display:flex;
  justify-content:space-between;
  align-items:center;
}

.btn{
  border:0;
  border-radius:10px;
  padding:10px 15px;
  background:#f97316;
  color:#fff;
  font-weight:bold;
  cursor:pointer;
}

.card{
  max-width:1100px;
  margin:20px auto;
  background:#0f172a;
  padding:20px;
  border-radius:20px;
}

.grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:15px;
}

@media(max-width:700px){
  .grid{grid-template-columns:1fr;}
}

input{
  width:100%;
  padding:12px;
  border-radius:10px;
  border:1px solid #334155;
  background:#020617;
  color:#fff;
}

.section{
  grid-column:1/-1;
  margin-top:15px;
  border-top:1px solid #1e293b;
  padding-top:15px;
}

.preview{
  margin-top:8px;
  width:100%;
  height:90px;
  object-fit:cover;
  border-radius:10px;
}

.ok{
  max-width:1100px;
  margin:auto;
  background:#064e3b;
  padding:10px;
  border-radius:10px;
}
</style>
</head>

<body>

<div class="top">
  <h2>Dashboard Admin</h2>
  <div>
    <a class="btn" href="/" target="_blank">Lihat</a>
    <form method="POST" action="/admin/logout" style="display:inline;">
      <button class="btn">Logout</button>
    </form>
  </div>
</div>

<% if (success) { %>
<div class="ok">Berhasil disimpan</div>
<% } %>

<form class="card" method="POST" action="/admin/save">
<div class="grid">

<div style="grid-column:1/-1">
<label>Judul</label>
<input name="siteTitle" value="<%= config.siteTitle %>">
</div>

<div>
<label>Foto</label>
<input name="profilePhoto" value="<%= config.profilePhoto %>">
<img src="<%= config.profilePhoto %>" class="preview">
</div>

<div>
<label>Alt</label>
<input name="profileAlt" value="<%= config.profileAlt %>">
</div>

<div class="section">
<h3>Background</h3>
</div>

<div>
<label>Background Desktop</label>
<input name="background" value="<%= config.background %>">
<img src="<%= config.background %>" class="preview">
</div>

<div>
<label>Background Mobile</label>
<input name="background_mobile" value="<%= config.background_mobile %>">
<img src="<%= config.background_mobile || config.background %>" class="preview">
</div>

<div class="section">
<h3>WhatsApp</h3>
</div>

<div><input name="wa1" value="<%= config.wa1 %>"></div>
<div><input name="wa2" value="<%= config.wa2 %>"></div>
<div><input name="wa3" value="<%= config.wa3 %>"></div>

<div class="section">
<h3>Telegram</h3>
</div>

<div><input name="tg1" value="<%= config.tg1 %>"></div>
<div><input name="tg2" value="<%= config.tg2 %>"></div>

<div class="section">
<h3>LiveChat</h3>
</div>

<div><input name="lc1" value="<%= config.lc1 %>"></div>
<div><input name="lc2" value="<%= config.lc2 %>"></div>

</div>

<button class="btn" style="width:100%;margin-top:20px;">SIMPAN</button>
</form>

</body>
</html>
